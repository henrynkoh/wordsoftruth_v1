<div class="youtube-automation-landing">
  <div class="hero-section">
    <div class="container-fluid">
      <div class="row align-items-center min-vh-100">
        <div class="col-lg-6">
          <div class="hero-content">
            <h1 class="hero-title">
              <span class="hero-icon">📺</span>
              YouTube 동영상 자동화
              <span class="hero-subtitle">유튜브 → YouTube Shorts 변환</span>
            </h1>
            <p class="hero-description">
              기존 YouTube 설교 동영상 URL을 입력하면 자막/설명을 추출하여 
              새로운 YouTube Shorts를 자동 생성합니다. AI 기반 콘텐츠 분석과 
              한국어 TTS로 전문적인 세로형 동영상을 제작합니다.
            </p>
            <!-- Quick Stats -->
            <div class="quick-stats">
              <div class="stat-item">
                <span class="stat-number"><%= @processing_stats[:total_processed] %></span>
                <span class="stat-label">총 처리</span>
              </div>
              <div class="stat-item">
                <span class="stat-number"><%= @processing_stats[:success_rate] %>%</span>
                <span class="stat-label">성공률</span>
              </div>
              <div class="stat-item">
                <span class="stat-number"><%= @processing_stats[:today_processed] %></span>
                <span class="stat-label">오늘 처리</span>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="automation-form-container">
            <div class="form-header">
              <h3>동영상 URL 입력</h3>
              <p>YouTube 동영상 URL들을 입력하여 Shorts 자동 생성을 시작 하세요</p>
            </div>
            <%= form_with url: start_automation_youtube_automation_index_path, method: :post, local: true, class: "automation-form" do |form| %>
              <div class="form-group">
                <label for="youtube_urls" class="form-label">
                  🎬 YouTube 동영상 URL 목록
                </label>
                <%= form.text_area :youtube_urls, rows: 6, class: "form-control", placeholder: "한 줄에 하나씩 붙여넣기 또는 여러 개를 쉼표/공백으로 구분" %>
                <div class="form-help">
                  <small>예시: https://www.youtube.com/watch?v=xxxxxx</small>
                </div>
              </div>
              <div class="form-actions">
                <%= form.submit "자동 생성 시작", class: "btn btn-primary" %>
                <button type="button" class="btn btn-outline-secondary" onclick="clearForm()">초기화</button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if @recent_batches.present? %>
    <div class="recent-batches-section">
      <h2>최근 자동화 배치</h2>
      <ul class="recent-batch-list">
        <% @recent_batches.each do |batch| %>
          <li>
            <span class="batch-id">배치 ID: <%= batch.id %></span>
            <span class="batch-status">상태: <%= batch.status %></span>
            <span class="batch-created">생성일: <%= batch.created_at.strftime('%Y-%m-%d %H:%M') %></span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>

<script>
  function clearForm() {
    document.querySelector('.automation-form textarea').value = '';
  }
</script>
